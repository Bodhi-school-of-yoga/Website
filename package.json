{
  "name": "bodhi",
  "version": "1.0.0",
  "private": true,
  "description": "Bodhi - Yoga Brand Website (Next.js + Strapi + PostgreSQL)",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:cms": "turbo run dev --filter=cms",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=web",
    "build:cms": "turbo run build --filter=cms",
    "start": "turbo run start",
    "start:web": "turbo run start --filter=web",
    "start:cms": "turbo run start --filter=cms",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@11.1.0",
  "dependencies": {
    "@google/design.md": "^0.1.1"
  },
  "volta": {
    "node": "24.15.0",
    "pnpm": "11.1.0"
  }
}
