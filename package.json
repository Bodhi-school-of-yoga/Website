{
  "name": "bodhi",
  "version": "1.0.0",
  "private": true,
  "description": "Bodhi - Yoga Brand Website (Next.js + Strapi + PostgreSQL)",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:web": "npm run dev -w web",
    "dev:cms": "npm run dev -w cms",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build -w web",
    "build:cms": "npm run build -w cms",
    "start": "npm run start --workspaces --if-present",
    "start:web": "npm run start -w web",
    "start:cms": "npm run start -w cms",
    "clean": "rm -rf node_modules apps/*/node_modules"
  },
  "devDependencies": {
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  }
}
