{
  "name": "bodhi",
  "version": "1.0.0",
  "private": true,
  "description": "Bodhi - Yoga Brand Website (Next.js + Strapi + PostgreSQL)",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:cms": "cd apps/cms && npm run develop",
    "build:web": "npm run build --workspace=apps/web",
    "build:cms": "cd apps/cms && npm run build",
    "start:web": "npm run start --workspace=apps/web",
    "start:cms": "cd apps/cms && npm run start",
    "lint:web": "npm run lint --workspace=apps/web",
    "install:cms": "cd apps/cms && npm install"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
